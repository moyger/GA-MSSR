# GA-MSSR Prop Firm Bot Configuration
# ====================================
# Copy this file for each prop firm account:
#   cp .env.propfirm.example .env.propfirm.fundednext
#   cp .env.propfirm.example .env.propfirm.myfundedfutures
#
# Run:
#   .venv/bin/python scripts/run_live_futures.py --env .env.propfirm.fundednext
#   .venv/bin/python scripts/run_live_futures.py --env .env.propfirm.myfundedfutures

# IBKR (data only — read-only connection to TWS/Gateway)
# Use a DIFFERENT client ID from personal bot (default=1)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=2

# TradersPost webhook (one per broker/prop firm account)
TRADERSPOST_WEBHOOK_URL=

# Contract
CONTRACT_ROOT=MNQ
TRADE_SIZE=1

# Prop firm risk limits (adjust per firm/account)
# FundedNext $50K Rapid Challenge:
#   Daily loss: $1,000 (soft breach), our stop: $500
#   Trailing MLL: $2,000 (EOD, locks at starting balance)
#   Profit target: $3,000
#   No consistency rule
# MyFundedFutures: adjust values to match their rules
FN_ACCOUNT_SIZE=50000
FN_DAILY_LOSS_LIMIT=500
FN_TRAILING_MAX_LOSS=2000
FN_PROFIT_TARGET=3000
FN_CONSISTENCY_PCT=0.0

# State directory (MUST be unique per account to avoid conflicts)
# Examples:
#   STATE_DIR=live_futures/state/fundednext
#   STATE_DIR=live_futures/state/myfundedfutures
STATE_DIR=live_futures/state/fundednext

# Slack notifications (optional)
SLACK_WEBHOOK_URL=
